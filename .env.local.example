# ─────────────────────────────────────────────────────────────────────────────
# Voorbeeld voor `.env.local`: kopieer naar `.env.local` en vul onderaan de drie waarden in.
# Alleen `.env.local.example` hoort in git; jouw echte `.env.local` met codes staat in .gitignore.
#
# Stappen:
# 1. Supabase Dashboard → je project → Project Settings (tandwiel) → API
# 2. "Project URL" kopiëren → hieronder bij NEXT_PUBLIC_SUPABASE_URL
# 3. Key "anon" / "public" kopiëren → NEXT_PUBLIC_SUPABASE_ANON_KEY
# 4. Key "service_role" (Reveal) kopiëren → SUPABASE_SERVICE_ROLE_KEY
# 5. Opslaan, daarna `npm run dev` opnieuw starten
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://VERVANG-DIT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VERVANG-DIT-PLAK-ANON-KEY-HIER
SUPABASE_SERVICE_ROLE_KEY=VERVANG-DIT-PLAK-SERVICE-ROLE-HIER

# Zoho SMTP (contactformulier, registratie, …) — productie: info@vysionkassa.com
# ZOHO_EMAIL=info@vysionkassa.com
# ZOHO_PASSWORD=

# Optioneel: Sentry performance traces (0–1). Zonder dit: 10% in production, 100% in development.
# SENTRY_TRACES_SAMPLE_RATE=0.1
